{
    "name": "hiblaphp/migrations",
    "description": "Cli and Migration Tooling for Hibla Database Ecosystem",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Migrations\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "hiblaphp/query-builder": "dev-main",
        "symfony/console": "^7.3",
        "doctrine/inflector": "^2.1",
        "nesbot/carbon": "^3.10"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "bin": [
        "bin/hibla-db"
    ],
    "scripts": {
        "post-install-cmd": [
            "@php -r \"if (!is_dir('config')) { echo '\\nRun: ./vendor/bin/hibla-db init\\n\\n'; }\""
        ],
        "post-update-cmd": [
            "@php -r \"if (!is_dir('config')) { echo '\\nRun: ./vendor/bin/hibla-db init\\n\\n'; }\""
        ],
        "test": "./vendor/bin/pest",
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "analyze": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
